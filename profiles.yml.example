# Copy to ~/.dbt/profiles.yml and fill in real values. NEVER commit the real file.
# Auth: OAuth via Application Default Credentials — run once:
#   gcloud auth application-default login
analytics_engineering_portfolio:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: oauth
      project: career-analytics-portfolio   # your GCP project
      dataset: dbt_dev
      location: US                          # thelook_ecommerce lives in the US multi-region
      threads: 4
      priority: interactive
    prod:
      type: bigquery
      method: oauth
      project: career-analytics-portfolio
      dataset: analytics
      location: US
      threads: 8
      priority: interactive
